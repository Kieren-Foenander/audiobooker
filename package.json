{
  "name": "audiobooker",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter frontend dev",
    "build": "pnpm --filter frontend build",
    "db:generate": "pnpm --filter frontend db:generate",
    "db:migrate": "pnpm --filter frontend db:migrate",
    "worker": "cd worker && uv run python -m worker run",
    "typecheck": "pnpm --filter frontend typecheck"
  },
  "packageManager": "pnpm@10.12.4",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "lightningcss"
    ]
  }
}
